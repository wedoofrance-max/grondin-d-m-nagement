# ─── Base de données PostgreSQL (Neon, Supabase, Railway, etc.) ───────────────
# URL utilisée par Prisma via le connection pooler
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1"
# URL directe (migration Prisma, sans pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Email (Gmail SMTP via Nodemailer) ────────────────────────────────────────
# Adresse Gmail utilisée pour l'envoi des emails
EMAIL_USER="votre-compte@gmail.com"
# Mot de passe d'application Google (pas le mdp de connexion)
# Générer sur : https://myaccount.google.com/apppasswords
EMAIL_PASS="xxxx xxxx xxxx xxxx"
# Adresse interne de l'équipe Grondin qui reçoit les notifications de devis
EMAIL_GRONDIN="contact@grondin-demenagement.fr"

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ─── Sécurité des crons Vercel ────────────────────────────────────────────────
# Token secret passé dans le header Authorization: Bearer <token>
# Générer avec : openssl rand -base64 32
CRON_SECRET="votre-secret-cron-32-caracteres-min"
